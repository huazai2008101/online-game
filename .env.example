# ========================================
# 服务配置
# ========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug
LOG_FORMAT=json

# 服务发现
SERVICE_NAME=gateway
SERVICE_VERSION=1.0.0
SERVICE_ID=

# ========================================
# 数据库配置
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=online_game
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_TIMEZONE=UTC

# 连接池配置
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=10m

# 慢查询阈值
DB_SLOW_THRESHOLD=100ms

# ========================================
# Redis 配置
# ========================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# ========================================
# NATS 配置
# ========================================
NATS_ADDR=nats://localhost:4222
NATS_USER=
NATS_PASSWORD=
NATS_CLIENT_NAME=

# JetStream 配置
NATS_JS_ENABLED=true
NATS_JS_DOMAIN=online-game
NATS_JS_API_PREFIX=
NATS_JS_EVENT_DELIVERED=events.delivered

# ========================================
# JWT 配置
# ========================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=720h
JWT_ISSUER=online-game
JWT_AUDIENCE=online-game-api

# ========================================
# CORS 配置
# ========================================
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# ========================================
# 限流配置
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=1000
RATE_LIMIT_BURST=100
RATE_LIMIT_CLEANUP_INTERVAL=1m

# IP 限流
RATE_LIMIT_IP_ENABLED=true
RATE_LIMIT_IP_REQUESTS_PER_MINUTE=60
RATE_LIMIT_IP_BURST=10

# ========================================
# WebSocket 配置
# ========================================
WS_ENABLED=true
WS_PATH=/ws
WS_READ_BUFFER_SIZE=4096
WS_WRITE_BUFFER_SIZE=4096
WS_PING_PERIOD=54s
WS_PONG_WAIT=60s
WS_WRITE_WAIT=10s
WS_MAX_MESSAGE_SIZE=1048576

# 心跳配置
WS_HEARTBEAT_INTERVAL=30s
WS_HEARTBEAT_TIMEOUT=60s

# ========================================
# Actor 配置
# ========================================
ACTOR_MAILBOX_SIZE=1000
ACTOR_SUPERVISIOR_STRATEGY=one_for_one
ACTOR_MAX_RESTARTS=10
ACTOR_MAX_RESTART_DURATION=1m

# ========================================
# 缓存配置
# ========================================
CACHE_ENABLED=true
CACHE_DEFAULT_EXPIRATION=5m
CACHE_CLEANUP_INTERVAL=10m
CACHE_MAX_ITEMS=10000

# 本地缓存
LOCAL_CACHE_SIZE=10000
LOCAL_CACHE_TTL=5m

# ========================================
# 会话配置
# ========================================
SESSION_STORE=redis
SESSION_COOKIE_NAME=session
SESSION_EXPIRATION=24h
SESSION_REFRESH_INTERVAL=1h

# ========================================
# 监控配置
# ========================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_NAMESPACE=online_game
PROMETHEUS_SUBSYSTEM=api

# ========================================
# 链路追踪配置
# ========================================
TRACE_ENABLED=true
TRACE_SAMPLE_RATE=0.1
TRACE_ENDPOINT=http://localhost:4318
TRACE_BATCH_TIMEOUT=5s
TRACE_EXPORT_TIMEOUT=30s

# Jaeger
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=/var/log/online-game/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30
LOG_COMPRESS=true

# ========================================
# API 配置
# ========================================
API_TIMEOUT=30s
API_MAX_HEADER_SIZE=1048576
API_READ_TIMEOUT=30s
API_WRITE_TIMEOUT=30s
API_IDLE_TIMEOUT=120s

# API 版本
API_VERSION=v1
API_PREFIX=/api/v1

# ========================================
# 文件存储配置
# ========================================
STORAGE_TYPE=local
STORAGE_PATH=/var/lib/online-game/uploads
STORAGE_MAX_FILE_SIZE=104857600
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# S3 配置 (如果使用 S3)
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ========================================
# 邮件配置
# ========================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@online-game.com
SMTP_FROM_NAME=Online Game

# ========================================
# SMS 配置
# ========================================
SMS_ENABLED=false
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM=

# ========================================
# 支付配置
# ========================================
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_CURRENCY=USD

# ========================================
# 特性开关
# ========================================
FEATURE_MAINTENANCE_MODE=false
FEATURE_REGISTRATION_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=true
FEATURE_CHAT_ENABLED=true
FEATURE_LEADERBOARD_ENABLED=true
FEATURE_TOURNAMENT_ENABLED=true
FEATURE_STORE_ENABLED=true

# ========================================
# 安全配置
# ========================================
# 密码哈希
PASSWORD_HASH_COST=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# CSRF
CSRF_ENABLED=true
CSRF_SECRET=change-this-in-production

# 加密
ENCRYPTION_KEY=change-this-to-32-byte-key

# ========================================
# 开发配置
# ========================================
DEV_HOT_RELOAD=true
DEV_DEBUG_PPROF=true
DEV_PPROF_PORT=6060

# ========================================
# 部署配置
# ========================================
DEPLOY_ENV=development
DEPLOY_REGION=
DEPLOY_ZONE=

# Kubernetes
KUBERNETES_NAMESPACE=online-game
KUBERNETES_CONFIGMAP=
KUBERNETES_SECRET=
